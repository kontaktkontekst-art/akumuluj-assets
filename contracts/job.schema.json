{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kontaktkontekst-art/akumuluj-assets/contracts/job.schema.json",
  "title": "Akumuluj Pipeline Job",
  "description": "State machine joba w pipeline Akumuluj",
  "type": "object",
  "required": ["job_id", "telegram_chat_id", "input_topic", "stage"],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^akumuluj-[0-9]{8}-[0-9]{3,}$",
      "example": "akumuluj-20240309-001"
    },
    "telegram_chat_id": {
      "type": "string",
      "description": "Twój Telegram chat ID"
    },
    "telegram_message_id": {
      "type": ["integer", "null"],
      "description": "ID wiadomości z draftem skryptu"
    },
    "input_topic": {
      "type": "string",
      "description": "Oryginalny input z Telegrama"
    },
    "stage": {
      "type": "string",
      "enum": [
        "script_generating",
        "awaiting_script_approval",
        "script_revision",
        "script_approved",
        "voiceover_generating",
        "html_generating",
        "rendering",
        "awaiting_video_approval",
        "done",
        "cancelled",
        "error"
      ],
      "description": "Aktualny etap pipeline"
    },
    "stage_error": {
      "type": ["string", "null"],
      "description": "Opis błędu jeśli stage = error"
    },
    "stages_log": {
      "type": "array",
      "description": "Historia etapów",
      "items": {
        "type": "object",
        "required": ["stage", "at"],
        "properties": {
          "stage": { "type": "string" },
          "at": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["started", "done", "failed"] },
          "note": { "type": ["string", "null"] }
        }
      }
    },
    "script_revision": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Ile razy skrypt był regenerowany"
    },
    "user_feedback": {
      "type": ["string", "null"],
      "description": "Feedback przy rewizji"
    },
    "script_url": {
      "type": ["string", "null"],
      "description": "URL do script.json na S3"
    },
    "artifacts": {
      "type": "object",
      "properties": {
        "voiceover_mp3_url": { "type": ["string", "null"], "format": "uri" },
        "html_url": { "type": ["string", "null"], "format": "uri" },
        "mp4_url": { "type": ["string", "null"], "format": "uri" },
        "thumbnail_url": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
