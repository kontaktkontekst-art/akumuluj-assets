{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/kontaktkontekst-art/akumuluj-assets/contracts/script.schema.json",
  "title": "Akumuluj Script",
  "description": "Kontrakt danych skryptu shorta Akumuluj",
  "type": "object",
  "required": ["job_id", "topic", "status", "voiceover", "scenes"],
  "properties": {
    "job_id": {
      "type": "string",
      "pattern": "^akumuluj-[0-9]{8}-[0-9]{3,}$",
      "description": "Unikalny identyfikator joba. Format: akumuluj-YYYYMMDD-NNN",
      "example": "akumuluj-20240309-001"
    },
    "topic": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200,
      "description": "Temat shorta — oryginalny input od użytkownika"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "approved", "rejected", "in_production", "done"],
      "description": "Status skryptu w pipeline"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "approved_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Numer rewizji — rośnie przy każdym regenerate"
    },
    "voiceover": {
      "type": "object",
      "required": ["text", "duration_target_s"],
      "properties": {
        "text": {
          "type": "string",
          "minLength": 50,
          "maxLength": 1000,
          "description": "Pełny tekst voiceoveru ~120 słów"
        },
        "duration_target_s": {
          "type": "integer",
          "minimum": 50,
          "maximum": 65,
          "description": "Docelowy czas trwania w sekundach"
        },
        "voice_id": {
          "type": ["string", "null"],
          "description": "ElevenLabs voice ID (np. Rafał)"
        },
        "generated_url": {
          "type": ["string", "null"],
          "format": "uri",
          "description": "URL do wygenerowanego MP3 na S3"
        },
        "generated_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 4,
      "maxItems": 10,
      "items": {
        "type": "object",
        "required": ["id", "type", "duration_s", "headline"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^scene_[0-9]{2}$",
            "description": "Format: scene_01, scene_02...",
            "example": "scene_01"
          },
          "type": {
            "type": "string",
            "enum": ["hook", "number", "compare", "lesson", "list", "chart", "question", "cta"],
            "description": "Typ sceny determinuje styl wizualny"
          },
          "duration_s": {
            "type": "integer",
            "minimum": 3,
            "maximum": 20,
            "description": "Czas trwania sceny w sekundach"
          },
          "headline": {
            "type": "string",
            "minLength": 2,
            "maxLength": 150,
            "description": "Główny tekst sceny"
          },
          "subtext": {
            "type": ["string", "null"],
            "maxLength": 200,
            "description": "Opcjonalny tekst pomocniczy"
          },
          "visual_hint": {
            "type": "string",
            "minLength": 10,
            "maxLength": 500,
            "description": "Wskazówka wizualna dla AI generującego HTML"
          },
          "subs": {
            "type": "array",
            "description": "Timestamps napisów — opcjonalne",
            "items": {
              "type": "object",
              "required": ["w", "t"],
              "properties": {
                "w": { "type": "string", "description": "Słowo lub krótka fraza" },
                "t": { "type": "integer", "description": "Timestamp w ms od startu sceny" },
                "h": { "type": "boolean", "description": "Czy wyróżnić złotym kolorem" }
              }
            }
          },
          "data": {
            "type": ["object", "null"],
            "description": "Opcjonalne dane liczbowe dla wykresów",
            "properties": {
              "values": { "type": "array", "items": { "type": "number" } },
              "labels": { "type": "array", "items": { "type": "string" } },
              "unit": { "type": "string", "description": "np. 'zł', '%', 'lat'" }
            }
          }
        }
      }
    },
    "brand": {
      "type": "object",
      "properties": {
        "palette": {
          "type": "string",
          "enum": ["dark-teal", "dark-gold", "dark-silver"],
          "default": "dark-teal"
        },
        "visual_mood": {
          "type": "string",
          "description": "Ogólny nastrój wizualny. Np. 'analytical-confident', 'warm-motivational'"
        }
      }
    },
    "output": {
      "type": "object",
      "properties": {
        "html_url": { "type": ["string", "null"], "format": "uri" },
        "mp4_url": { "type": ["string", "null"], "format": "uri" },
        "thumbnail_url": { "type": ["string", "null"], "format": "uri" },
        "html_github_path": { "type": ["string", "null"], "description": "Ścieżka w repo jeśli approved" }
      }
    }
  }
}
